{
    "name": "playwright-template-ts",
    "version": "0.0.1",
    "private": false,
    "description": "",
    "license": "ISC",
    "author": "VElena",
    "scripts": {
        "lint": "eslint",
        "lint-staged": "lint-staged",
        "playwright": "playwright",
        "test:ui": "playwright test --ui -c ./playwright.config.ts --debug",
        "allure": "allure generate allure-results --clean -o allure-report",
        "allure:open": "allure open allure-report",
        "postinstall": "node scripts/postinstall.mts",
        "test": "playwright test -c playwright-ci.config.ts",
        "playwright:report": "playwright show-report playwright-report"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "~1.60.0",
        "@types/node": "^24.0.0",
        "@typescript-eslint/eslint-plugin": "8.59.3",
        "@typescript-eslint/parser": "8.59.3",
        "allure-commandline": "^2.32.0",
        "allure-js-commons": "3.9.0",
        "allure-playwright": "^3.3.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsonc": "^3.1.2",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "~17.6.0",
        "jsonc-eslint-parser": "^3.1.0",
        "lint-staged": "^17.0.4",
        "playwright": "1.60.0",
        "typescript": "6.0.3"
    },
    "engines": {
        "node": ">=24"
    },
    "lint-staged": {
        "*.(ts,json)": "eslint --fix"
    }
}
